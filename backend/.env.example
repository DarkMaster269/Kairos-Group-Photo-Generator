# ── Kairos Backend Environment Variables ─────────────────────────────────────
# Copy this file to .env and fill in real values.
# Never commit the filled-in .env to version control.

# ── AI Gate Provider ──────────────────────────────────────────────────────────
# Which LLM provider to use for Gate 1 and Gate 2 checks.
# Valid values: "gemini" | "anthropic"
GATE_PROVIDER=gemini

# Gemini API key (required when GATE_PROVIDER=gemini)
GEMINI_API_KEY=your_gemini_api_key_here

# Gemini model identifier
GEMINI_MODEL=gemini-1.5-flash

# Anthropic API key (required when GATE_PROVIDER=anthropic)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Anthropic model identifier
ANTHROPIC_MODEL=claude-3-5-sonnet-20240620

# ── Demo / Offline Mode ───────────────────────────────────────────────────────
# When set to "true", both AI gates use cached JSON responses from
# backend/app/cache/ instead of calling external LLM APIs.
# Use this for local demos, CI runs, or when API keys are unavailable.
# Valid values: "true" | "false"
DEMO_FALLBACK=false

# ── Server ────────────────────────────────────────────────────────────────────
# Port the uvicorn server listens on. Render/Fly.io inject this automatically.
PORT=8000
